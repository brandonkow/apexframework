{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Residential transaction records",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["transaction_id", "date", "geography", "property_type", "market_type", "record_kind", "currency", "source_ids"],
    "properties": {
      "transaction_id": {"type": "string", "minLength": 1},
      "date": {"type": "string", "format": "date"},
      "project_id": {"type": ["string", "null"]},
      "geography": {"type": "string", "minLength": 1},
      "submarket": {"type": ["string", "null"]},
      "property_type": {"type": "string", "minLength": 1},
      "market_type": {"type": "string", "enum": ["primary", "secondary"]},
      "record_kind": {"type": "string", "enum": ["individual", "aggregate"]},
      "period_label": {"type": ["string", "null"]},
      "period_start": {"type": ["string", "null"], "format": "date"},
      "period_end": {"type": ["string", "null"], "format": "date"},
      "period_coverage": {"type": ["string", "null"], "enum": ["full-year", "year-to-date", "quarter", "month", "custom", null]},
      "comparison_group": {"type": ["string", "null"]},
      "price": {"type": ["number", "null"], "exclusiveMinimum": 0},
      "volume": {"type": ["integer", "null"], "minimum": 0},
      "total_value": {"type": ["number", "null"], "minimum": 0},
      "median_price": {"type": ["number", "null"], "minimum": 0},
      "median_price_psf": {"type": ["number", "null"], "minimum": 0},
      "currency": {"type": "string", "minLength": 3},
      "area_sqft": {"type": ["number", "null"], "exclusiveMinimum": 0},
      "price_psf": {"type": ["number", "null"], "exclusiveMinimum": 0},
      "bedrooms": {"type": ["number", "null"], "minimum": 0},
      "tenure": {"type": ["string", "null"]},
      "price_basis": {"type": "string", "enum": ["gross", "net", "asking", "achieved", "unknown"]},
      "segment": {"type": ["string", "null"]},
      "source_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
      "notes": {"type": ["string", "null"]}
    },
    "additionalProperties": true
  }
}
