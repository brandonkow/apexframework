{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Comparable residential projects",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["project_id", "project_name", "geography", "product_type", "total_units", "source_ids"],
    "properties": {
      "project_id": {"type": "string", "minLength": 1},
      "project_name": {"type": "string", "minLength": 1},
      "developer": {"type": ["string", "null"]},
      "location": {"type": ["string", "null"]},
      "geography": {"type": "string", "minLength": 1},
      "submarket": {"type": ["string", "null"]},
      "latitude": {"type": ["number", "null"], "minimum": -90, "maximum": 90},
      "longitude": {"type": ["number", "null"], "minimum": -180, "maximum": 180},
      "product_type": {"type": "string", "minLength": 1},
      "tenure": {"type": ["string", "null"]},
      "blocks": {"type": ["integer", "null"], "minimum": 0},
      "storeys": {"type": ["integer", "null"], "minimum": 0},
      "total_units": {"type": "integer", "minimum": 0},
      "units_released": {"type": ["integer", "null"], "minimum": 0},
      "verified_sales": {"type": ["integer", "null"], "minimum": 0},
      "reported_bookings": {"type": ["integer", "null"], "minimum": 0},
      "recent_sales": {"type": ["integer", "null"], "minimum": 0},
      "recent_sales_months": {"type": ["number", "null"], "exclusiveMinimum": 0},
      "launch_date": {"type": ["string", "null"], "format": "date"},
      "survey_date": {"type": ["string", "null"], "format": "date"},
      "expected_completion": {"type": ["string", "null"], "format": "date"},
      "gross_price_min": {"type": ["number", "null"], "minimum": 0},
      "gross_price_max": {"type": ["number", "null"], "minimum": 0},
      "net_price_min": {"type": ["number", "null"], "minimum": 0},
      "net_price_max": {"type": ["number", "null"], "minimum": 0},
      "size_sqft_min": {"type": ["number", "null"], "exclusiveMinimum": 0},
      "size_sqft_max": {"type": ["number", "null"], "exclusiveMinimum": 0},
      "target_buyer": {"type": ["string", "null"]},
      "performance_class": {"type": "string", "enum": ["strong", "average", "weak", "unknown"]},
      "comparison_role_override": {
        "type": ["string", "null"],
        "enum": ["direct", "aspirational", "control", "contextual", "excluded", null]
      },
      "override_reason": {"type": ["string", "null"]},
      "comparable_scores": {
        "type": ["object", "null"],
        "properties": {
          "buyer_similarity": {"type": "number", "minimum": 0, "maximum": 5},
          "location_accessibility": {"type": "number", "minimum": 0, "maximum": 5},
          "product_tenure": {"type": "number", "minimum": 0, "maximum": 5},
          "size_total_price": {"type": "number", "minimum": 0, "maximum": 5},
          "timing": {"type": "number", "minimum": 0, "maximum": 5},
          "scale_density": {"type": "number", "minimum": 0, "maximum": 5},
          "brand_positioning": {"type": "number", "minimum": 0, "maximum": 5}
        },
        "additionalProperties": false
      },
      "source_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
      "notes": {"type": ["string", "null"]}
    },
    "additionalProperties": true
  }
}
