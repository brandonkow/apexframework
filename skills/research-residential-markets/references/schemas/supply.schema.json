{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Residential supply records",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["record_id", "period_year", "geography", "property_type", "status", "units", "source_ids"],
    "properties": {
      "record_id": {"type": "string", "minLength": 1},
      "period_year": {"type": "integer", "minimum": 1900, "maximum": 2200},
      "geography": {"type": "string", "minLength": 1},
      "submarket": {"type": ["string", "null"]},
      "property_type": {"type": "string", "minLength": 1},
      "status": {"type": "string", "enum": ["existing", "incoming", "planned"]},
      "units": {"type": "integer", "minimum": 0},
      "project_id": {"type": ["string", "null"]},
      "tenure": {"type": ["string", "null"]},
      "segment": {"type": ["string", "null"]},
      "expected_completion": {"type": ["string", "null"], "format": "date"},
      "delivery_confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
      "source_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
      "notes": {"type": ["string", "null"]}
    },
    "additionalProperties": true
  }
}
