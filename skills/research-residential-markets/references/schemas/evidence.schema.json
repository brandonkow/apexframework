{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atomic evidence record",
  "type": "object",
  "required": [
    "evidence_id",
    "claim",
    "source_type",
    "source_reference",
    "source_date",
    "accessed_date",
    "confidence",
    "verification_status"
  ],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "claim": {"type": "string", "minLength": 3},
    "value": {},
    "unit": {"type": ["string", "null"]},
    "geography": {"type": ["string", "null"]},
    "project_id": {"type": ["string", "null"]},
    "source_type": {
      "type": "string",
      "enum": [
        "official",
        "validated-database",
        "developer-document",
        "primary-survey",
        "portal",
        "media",
        "other"
      ]
    },
    "source_reference": {"type": "string", "minLength": 3},
    "source_date": {"type": "string", "format": "date"},
    "accessed_date": {"type": "string", "format": "date"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "verification_status": {
      "type": "string",
      "enum": ["verified", "corroborated", "single-source", "disputed", "rejected"]
    },
    "evidence_location": {"type": ["string", "null"]},
    "materiality": {"type": "string", "enum": ["critical", "material", "supporting"]},
    "notes": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
